# ============================================
# HR Screening Agent - Environment Variables
# ============================================

# Get your FREE Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Your Gmail address
GMAIL_USER=your_email@gmail.com

# Gmail App Password (NOT your real password!)
# How to get it: Google Account > Security > 2-Step Verification > App Passwords
GMAIL_APP_PASSWORD=your_16_character_app_password

# Your company name (shown in emails)
COMPANY_NAME=Saylani Tech
